generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FoodSource {
  MANUAL
  EDAMAM
  OPEN_FOOD_FACTS
  OTHER
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique @db.VarChar(320)
  name           String?     @db.VarChar(100)
  image          String?
  emailVerified  DateTime?   @map("email_verified")
  password_hash  String?     @db.VarChar(255)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  accounts       Account[]
  sessions       Session[]
  profile        UserProfile?
  weight_entries WeightEntry[]
  food_logs      FoodLog[]
  exercise_logs  ExerciseLog[]
  water_logs     WaterLog[]
  recipes        Recipe[]

  @@map("users")
}

model Account {
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  created_at DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AllowedEmail {
  id         String   @id @default(cuid())
  email      String   @unique @db.VarChar(320)
  is_active  Boolean  @default(true)
  notes      String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("allowed_emails")
}

model UserProfile {
  id               String   @id @default(cuid())
  user_id          String   @unique
  display_name     String?  @db.VarChar(100)
  date_of_birth    DateTime?
  height_feet      Int?
  height_inches    Int?
  target_weight_lb Decimal? @db.Decimal(5, 2)
  target_calories  Int      @default(2000)
  target_calories_sun Int?
  target_calories_mon Int?
  target_calories_tue Int?
  target_calories_wed Int?
  target_calories_thu Int?
  target_calories_fri Int?
  target_calories_sat Int?
  water_goal_oz     Int      @default(64)
  avg_tdee_calories Int?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model WeightEntry {
  id          String   @id @default(cuid())
  user_id     String
  weight_lb   Decimal  @db.Decimal(5, 2)
  recorded_at DateTime @default(now())
  notes       String?  @db.Text
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, recorded_at])
  @@map("weight_entries")
}

model FoodItem {
  id           String    @id @default(cuid())
  name         String    @db.VarChar(200)
  brand        String?   @db.VarChar(120)
  upc          String?   @db.VarChar(32)
  serving_size Decimal?  @db.Decimal(7, 2)
  serving_unit String?   @db.VarChar(20)
  calories     Int
  protein_g    Decimal   @default(0) @db.Decimal(7, 2)
  carbs_g      Decimal   @default(0) @db.Decimal(7, 2)
  fat_g        Decimal   @default(0) @db.Decimal(7, 2)
  fiber_g      Decimal?  @db.Decimal(7, 2)
  sugar_g      Decimal?  @db.Decimal(7, 2)
  sodium_mg    Decimal?  @db.Decimal(9, 2)
  source       FoodSource @default(MANUAL)
  source_ref   String?   @db.VarChar(120)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  food_logs    FoodLog[]
  recipe_ingredients RecipeIngredient[]

  @@index([upc])
  @@index([name])
  @@map("food_items")
}

model FoodLog {
  id           String   @id @default(cuid())
  user_id      String
  food_item_id String
  servings     Decimal  @default(1) @db.Decimal(6, 2)
  consumed_at  DateTime @default(now())
  meal_type    String?  @db.VarChar(32)
  notes        String?  @db.Text
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  food_item    FoodItem @relation(fields: [food_item_id], references: [id], onDelete: Cascade)

  @@index([user_id, consumed_at])
  @@map("food_logs")
}

model ExerciseLog {
  id               String   @id @default(cuid())
  user_id          String
  activity_name    String   @db.VarChar(120)
  duration_minutes Int
  calories_burned  Int
  performed_at     DateTime @default(now())
  notes            String?  @db.Text
  created_at       DateTime @default(now())
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, performed_at])
  @@map("exercise_logs")
}

model WaterLog {
  id          String   @id @default(cuid())
  user_id     String
  amount_oz   Int
  consumed_at DateTime @default(now())
  notes       String?  @db.Text
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, consumed_at])
  @@map("water_logs")
}

model Recipe {
  id          String   @id @default(cuid())
  user_id     String
  name        String   @db.VarChar(160)
  servings    Decimal  @default(1) @db.Decimal(6, 2)
  notes       String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@index([user_id, created_at])
  @@map("recipes")
}

model RecipeIngredient {
  id          String   @id @default(cuid())
  recipe_id   String
  food_item_id String
  quantity    Decimal  @default(1) @db.Decimal(7, 2)
  created_at  DateTime @default(now())
  recipe      Recipe   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  food_item   FoodItem @relation(fields: [food_item_id], references: [id], onDelete: Restrict)

  @@index([recipe_id, created_at])
  @@index([food_item_id])
  @@map("recipe_ingredients")
}
